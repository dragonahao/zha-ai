{
  "manifest_version": 3,
  "name": "zha-lanhu助手",
  "version": "1.0.1",
  "description": "zha-lanhu助手 - 页面元素分析与提取工具",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "zha-lanhu助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html",
    "open_at_install": false
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://aistudio.google.com/*"],
      "js": ["content/google-ai-injector.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/analyzer.js","shared/bean.js", "shared/ui-common.js", "shared/prompt-select-options.js", "shared/llm-select-options.js", "shared/gemini-executor.js", "shared/deepseek-executor.js", "shared/doubao-executor.js", "shared/claude-executor.js", "documents/ai-ds-db.md"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "打开zha-lanhu助手侧边栏"
    }
  }
}
